{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Write(*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(find * -delete*)",
      "Bash(find * -exec rm*)",
      "Bash(trash *)",
      "Bash(unlink *)"
    ]
  }
}